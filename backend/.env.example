# Backend only. Copy to backend/.env (or merge with root .env for docker-compose).
# Root .env.example has shared vars (PORT, ENV). This file has backend-specific vars.

# Embedding model (sentence-transformers). Leave empty to use default: all-MiniLM-L6-v2
EMBEDDING_MODEL=

# Optional: short path for Hugging Face cache on Windows (e.g. C:\hf_cache)
# HF_HOME=

# Chroma vector store
CHROMA_PATH=chroma_db
CHROMA_COLLECTION=law_chunks

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Retrieval
TOP_K=5
MIN_CHUNK_WORDS=5
MIN_CHUNK_CHARS=50

# CourtListener (backend/cli/rebuild_index.py)
COURTLISTENER_API_TOKEN=
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# RAG – Groq API (put real key only in .env, never commit)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
EXPORTS_TEXTS_DIR=exports/courtlistener_first_cases/texts
