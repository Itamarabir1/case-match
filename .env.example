# Embedding model (sentence-transformers). Leave empty to use default: all-MiniLM-L6-v2
EMBEDDING_MODEL=

# Optional: set to a short path if you see "Invalid disk cache / long paths" on Windows (e.g. C:\hf_cache)
# HF_HOME=

# Chroma vector store path (relative or absolute)
CHROMA_PATH=chroma_db
# Collection name (use law_chunks_2 etc. to avoid overwriting when testing)
CHROMA_COLLECTION=law_chunks

# Chunking (characters; ~1200–1600 ≈ 400 tokens)
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Retrieval (default number of similar cases returned)
TOP_K=5
MIN_CHUNK_WORDS=5
MIN_CHUNK_CHARS=50

# API (optional)
PORT=8000
ENV=development

# CourtListener (optional – for scripts/rebuild_first_courtlistener_cases.py)
COURTLISTENER_API_TOKEN=
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# RAG (scripts/rag_analysis.py) – Groq API
# IMPORTANT: put your real key only in local .env (never commit it)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Path to exported full case texts (for context)
EXPORTS_TEXTS_DIR=exports/courtlistener_first_cases/texts
